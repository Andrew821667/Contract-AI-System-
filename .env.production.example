# ==============================================
# Contract AI System — Production Environment
# ==============================================
# Copy to .env and fill in real values

# --- Application ---
APP_ENV=production
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET

# --- PostgreSQL ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://contract_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/contract_ai

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- LLM Providers ---
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# --- Frontend ---
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/api/v1/ws
