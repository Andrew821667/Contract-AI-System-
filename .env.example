# ==============================================
# CONTRACT AI SYSTEM - Environment Variables
# ==============================================

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/contract_ai

# ==============================================
# LLM API KEYS (v2.0 Multi-Model Routing)
# ==============================================

# DeepSeek-V3 (Primary Worker - 90% задач, $0.14/1M tokens)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v3
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.1

# Anthropic Claude 4.6 Sonnet (Expert Fallback - сложные задачи, $3.00/1M tokens)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6-20250227
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.1

# Google Gemini (быстрая и мощная модель с 1M контекстом)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI GPT-5.4 (Reserve Channel - $2.50/1M tokens)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_MODEL_MINI=gpt-5.4-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# ==============================================
# SMART ROUTER CONFIGURATION
# ==============================================
ROUTER_DEFAULT_MODEL=deepseek-v3
ROUTER_COMPLEXITY_THRESHOLD=0.8
ROUTER_ENABLE_FALLBACK=true

# Ollama (Local LLM — бесплатно, для простых задач)
# Установка: brew install ollama && ollama pull qwen3:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:7b

# Legacy providers (optional, для совместимости)
PERPLEXITY_API_KEY=pplx-...
YANDEX_API_KEY=...
YANDEX_FOLDER_ID=...
QWEN_API_KEY=...

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_data

# File Storage Paths
UPLOAD_DIR=./data/uploads
NORMALIZED_DIR=./data/normalized
REPORTS_DIR=./data/reports
TEMPLATES_DIR=./data/templates
EXPORTS_DIR=./data/exports

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# Streamlit UI
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Redis (optional, для кэширования)
REDIS_URL=redis://localhost:6379/0

# LLM Settings
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4000
LLM_TIMEOUT=120

# ==============================================
# RAG CONFIGURATION (v2.0)
# ==============================================
RAG_ENABLED=true
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ==============================================
# COST TRACKING
# ==============================================
COST_TRACKING_ENABLED=true

# Costs per 1M tokens (input)
COST_DEEPSEEK_INPUT=0.14
COST_CLAUDE_INPUT=3.00
COST_GPT4O_INPUT=2.50
COST_GPT4O_MINI_INPUT=0.15

# Costs per 1M tokens (output)
COST_DEEPSEEK_OUTPUT=0.28
COST_CLAUDE_OUTPUT=15.00
COST_GPT4O_OUTPUT=10.00
COST_GPT4O_MINI_OUTPUT=0.60

# ==============================================
# REQUEST SETTINGS
# ==============================================
REQUEST_TIMEOUT=120
MAX_RETRIES=3
RETRY_DELAY=1.0

# Security
# IMPORTANT: Generate a secure key for production!
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Email / SMTP Settings
# ======================
# For Gmail, use: smtp.gmail.com:587
# For Outlook, use: smtp-mail.outlook.com:587
# For custom SMTP, specify host and port
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Contract AI System

# ==============================================
# DOCKER DEPLOYMENT
# ==============================================
# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=changeme_in_production

# Redis password
REDIS_PASSWORD=changeme_in_production

# Nginx port
NGINX_HTTP_PORT=80

# Frontend URLs (for docker-compose frontend build)
NEXT_PUBLIC_API_URL=http://localhost:80
NEXT_PUBLIC_WS_URL=ws://localhost:80/api/v1/ws

# Seed users (initial admin/demo accounts)
SEED_ADMIN_PASSWORD=
SEED_LAWYER_PASSWORD=
SEED_VIP_PASSWORD=
SEED_DEMO_PASSWORD=
FORCE_RESEED=false
