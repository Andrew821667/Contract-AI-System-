# Contract AI System — Docker environment
# Copy to .env and fill in values before running docker compose up

# === REQUIRED ===
SECRET_KEY=CHANGE_ME_generate_with_python3_-c_import_secrets_secrets.token_urlsafe(32)
DEEPSEEK_API_KEY=your-deepseek-api-key

# === Database ===
POSTGRES_PASSWORD=contract_secure_2024
DATABASE_URL=postgresql://contract_user:contract_secure_2024@postgres:5432/contract_ai

# === Optional LLM keys ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
QWEN_API_KEY=
DEFAULT_LLM_PROVIDER=deepseek

# === Redis ===
REDIS_PASSWORD=redis_secure_2024

# === App ===
APP_ENV=production

# === Seed passwords (first run only) ===
SEED_ADMIN_PASSWORD=Admin123!
SEED_LAWYER_PASSWORD=Lawyer123!
SEED_VIP_PASSWORD=Vip12345!
SEED_DEMO_PASSWORD=Demo1234!

# === Nginx ===
NGINX_HTTP_PORT=80

# === Frontend (override if behind reverse proxy) ===
# NEXT_PUBLIC_API_URL=https://your-domain.com
# NEXT_PUBLIC_WS_URL=wss://your-domain.com/api/v1/ws
